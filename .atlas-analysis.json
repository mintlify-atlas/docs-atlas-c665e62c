{
  "projectType": "cli-tool",
  "projectName": "VectorLint",
  "projectDescription": "A static analysis and linting tool for validating vector embeddings, schemas, and AI/ML pipeline configurations.",
  "theme": "luma",
  "primaryColor": "#6366f1",
  "lightColor": "#818cf8",
  "darkColor": "#4338ca",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "installation"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/how-it-works", "concepts/rules-overview", "concepts/vector-schemas"]
          },
          {
            "group": "Guides",
            "pages": ["guides/ci-integration", "guides/custom-rules", "guides/vector-databases", "guides/migrating"]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/config-file", "configuration/ignore-patterns", "configuration/plugins"]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "CLI Commands",
            "pages": ["reference/commands-overview", "reference/lint", "reference/init", "reference/rules"]
          },
          {
            "group": "Built-in Rules",
            "pages": ["reference/rules/schema-rules", "reference/rules/dimension-rules", "reference/rules/metadata-rules"]
          },
          {
            "group": "Support",
            "pages": ["troubleshooting", "faq"]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Static analysis of vector embedding schemas and dimensions",
    "Configurable rule sets for validating AI/ML pipeline definitions",
    "CI/CD integration via exit codes and JSON output",
    "Custom rule authoring with a plugin API",
    "Support for popular vector databases (Pinecone, Weaviate, Qdrant, pgvector)",
    "Auto-fix suggestions for common schema mismatches",
    "Init command to bootstrap configuration from existing schemas"
  ],
  "publicApiSurface": [
    "vectorlint lint [path]",
    "vectorlint init",
    "vectorlint rules [--list] [--describe <rule>]",
    "vectorlint --config <file>",
    "vectorlint --fix",
    "vectorlint --format [json|text|sarif]",
    ".vectorlintrc.json / vectorlint.config.js",
    "Rule: schema/consistent-dimensions",
    "Rule: schema/no-undefined-fields",
    "Rule: metadata/required-fields",
    "Rule: metadata/type-mismatch",
    "Rule: dimensions/power-of-two",
    "Rule: dimensions/model-mismatch"
  ]
}
